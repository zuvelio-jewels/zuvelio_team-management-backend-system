# Railway backend environment variables
# Paste these into the Railway backend service Variables tab.
# Do not wrap values in quotes.

# From Railway PostgreSQL service in the same project
DATABASE_URL=postgresql://...

# Generate with: npm run secrets:generate
JWT_SECRET=
JWT_REFRESH_SECRET=

# Token lifetimes
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Frontend origins (comma-separated, no spaces required)
CORS_ORIGIN=https://app.zuvelio.com,https://admin.zuvelio.com

# Runtime
NODE_ENV=production
# PORT is managed by Railway automatically
