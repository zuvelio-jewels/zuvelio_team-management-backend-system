generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(EMPLOYEE)
  isActive  Boolean  @default(false)
  isApproved Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  refreshToken           String?
  passwordResetToken     String?
  passwordResetExpiresAt DateTime?
  failedLoginAttempts    Int       @default(0)
  lockedUntil            DateTime?

  assignedTasks      Task[]         @relation("AssignedTo")
  allottedTasks      Task[]         @relation("AllottedFrom")
  uploadedDocuments  TaskDocument[] @relation("UploadedDocuments")
  noteHistories      TaskNoteHistory[] @relation("NoteHistoryAuthor")
  attendance         Attendance[]
  leaves             Leave[]

  // Task Assignment
  isAssignable        Boolean @default(false)

  // Projection Assignment
  isProjectAssignable Boolean @default(false)

  // Activity Monitoring
  isMonitoringEnabled Boolean @default(true)
  lastActivityAt      DateTime?
  activityEvents      ActivityEvent[]
  activitySummaries   ActivitySummary[]
  monitoringConfig    MonitoringConfig?
  deviceTokens        DeviceToken[]

  // Projection Management - Employees with assigned projections
  projectionsAssigned Projection[] @relation("ProjectionsAssigned")
  projectionsCreated  Projection[] @relation("ProjectionsCreated")
  timeLogs            TimeLog[] @relation("TimeLogs")
  notificationsReceived Notification[] @relation("NotificationsReceived")
  projectionActions   ProjectionAction[] @relation("ProjectionActions")
}

model Task {
  id            Int       @id @default(autoincrement())
  title         String    @default("")
  cabin         String
  taskDetail    String
  completeBy    String    // TODAY, TOMORROW, WITHIN_3_DAYS, WITHIN_7_DAYS
  deadline      DateTime?
  personStatus  String    @default("NOT_STARTED") // NOT_STARTED, IN_PROGRESS, DONE
  note          String?
  alert         String?   // Auto-computed: COMPLETE_IN_TIME, LATE_COMPLETE, RE_WORK, etc.
  qcCheck       String?   // DONE, ISSUE
  remark        String?
  isPresent     Boolean   @default(true)
  updatedBy     DateTime?

  assignedToId  Int?
  assignedTo    User?     @relation("AssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  allottedFromId Int?
  allottedFrom   User?    @relation("AllottedFrom", fields: [allottedFromId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  documents     TaskDocument[]
  noteHistories TaskNoteHistory[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model TaskNoteHistory {
  id        Int      @id @default(autoincrement())
  taskId    Int
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  note      String
  authorId  Int?
  author    User?    @relation("NoteHistoryAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
}

model TaskDocument {
  id                 Int      @id @default(autoincrement())
  taskId             Int
  task               Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  fileName           String
  originalName       String
  mimeType           String
  size               Int
  url                String?  // Cloudinary secure URL
  cloudinaryPublicId String?  // Cloudinary public_id for deletion
  uploadedById       Int?
  uploadedBy         User?    @relation("UploadedDocuments", fields: [uploadedById], references: [id], onDelete: SetNull)
  createdAt          DateTime @default(now())
}

model Attendance {
  id        Int      @id @default(autoincrement())
  userId    Int
  date      DateTime
  checkIn   DateTime?
  checkOut  DateTime?
  user      User     @relation(fields: [userId], references: [id])
}

model Leave {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String
  fromDate  DateTime
  toDate    DateTime
  status    String   @default("PENDING")
  user      User     @relation(fields: [userId], references: [id])
}

enum Role {
  ADMIN
  MANAGER
  EMPLOYEE
}

// Activity Monitoring Models

model ActivityEvent {
  id                Int       @id @default(autoincrement())
  userId            Int
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  eventType         String    // KEYPRESS, CLICK, MOUSE_MOVE
  timestamp         DateTime  @default(now())
  
  // Keyboard event details
  keyCode           String?
  
  // Mouse event details
  mouseX            Int?
  mouseY            Int?
  clickType         String?   // LEFT, RIGHT, MIDDLE
  
  // Task correlation (optional)
  taskId            Int?
  
  // Metadata
  sessionId         String?   // To group events by browser session
  
  createdAt         DateTime  @default(now())
  
  @@index([userId])
  @@index([timestamp])
  @@index([userId, timestamp])
  @@index([taskId])
}

model ActivitySummary {
  id                Int       @id @default(autoincrement())
  userId            Int
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Time period (hour of the day)
  date              DateTime
  hour              Int       // 0-23
  
  // Aggregated metrics
  totalKeystrokes   Int       @default(0)
  totalClicks       Int       @default(0)
  totalMouseMovement Int      @default(0)
  idleTimeMinutes   Int       @default(0)
  
  // Task correlation
  taskId            Int?
  
  // Metadata
  isWorkingHours    Boolean   @default(true)
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  @@unique([userId, date, hour, taskId])
  @@index([userId])
  @@index([userId, date])
  @@index([date])
}

model MonitoringConfig {
  id                      Int       @id @default(autoincrement())
  userId                  Int       @unique
  user                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Monitoring settings
  isMonitoringEnabled     Boolean   @default(true)
  
  // Working hours (in 24-hour format, interpreted in timezoneOffsetHours)
  startWorkHour           Int       @default(9)    // 9 AM
  endWorkHour             Int       @default(18)   // 6 PM

  // UTC offset in hours (e.g. +5 for PKT, +0 for UTC, -5 for EST)
  timezoneOffsetHours     Int       @default(5)    // Default: PKT (UTC+5)

  // Idle threshold in minutes
  idleThresholdMinutes    Int       @default(5)
  
  // Department/Team (for bulk operations)
  departmentId            Int?      // Can add department later
  
  // Audit trail
  createdBy               Int?      // User ID who created this config
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
}

model DeviceToken {
  id          Int       @id @default(autoincrement())
  token       String    @unique
  userId      Int
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceName  String?
  isRevoked   Boolean   @default(false)
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([token])
}

// ========== PROJECTION MANAGEMENT SYSTEM ==========

model Projection {
  id                Int       @id @default(autoincrement())
  
  // Assignment Details
  employeeId        Int
  employee          User      @relation("ProjectionsAssigned", fields: [employeeId], references: [id], onDelete: Cascade)
  
  createdByAdminId  Int
  createdByAdmin    User      @relation("ProjectionsCreated", fields: [createdByAdminId], references: [id], onDelete: Restrict)
  
  // Task Description
  title             String
  description       String?
  
  // Time Allocation
  allocatedMinutes  Int       // Admin-assigned time budget
  assignedAt        DateTime  @default(now())
  
  // Status Tracking
  status            String    @default("PENDING")  // PENDING, ACCEPTED, IN_PROGRESS, COMPLETED, REJECTED, INCOMPLETE
  employeeAcceptedAt DateTime?
  employeeRejectedAt DateTime?
  completedAt       DateTime?
  rejectionReason   String?
  
  // Relationships
  timeLogs          TimeLog[]
  notifications     Notification[]
  projectionActions ProjectionAction[]
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  @@index([employeeId])
  @@index([createdByAdminId])
  @@index([status])
  @@index([assignedAt])
}

model TimeLog {
  id                Int       @id @default(autoincrement())
  projectionId      Int
  projection        Projection @relation(fields: [projectionId], references: [id], onDelete: Cascade)
  
  employeeId        Int
  employee          User      @relation("TimeLogs", fields: [employeeId], references: [id], onDelete: Cascade)
  
  // Session Details
  sessionStart      DateTime
  sessionEnd        DateTime?
  allocatedDuration Int       // minutes allocated for this projection
  actualDuration    Int       @default(0)  // minutes spent (computed from start/end + breaks)
  
  // Breaks/Pauses
  breaks            Break[]
  
  // Status tracking
  status            String    @default("active")  // active, paused, completed
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  @@index([projectionId])
  @@index([employeeId])
  @@index([sessionStart])
}

model Break {
  id        Int       @id @default(autoincrement())
  timeLogId Int
  timeLog   TimeLog   @relation(fields: [timeLogId], references: [id], onDelete: Cascade)
  
  startTime DateTime
  endTime   DateTime?
  duration  Int       @default(0)  // minutes
  
  createdAt DateTime  @default(now())
  
  @@index([timeLogId])
}

model Notification {
  id            Int       @id @default(autoincrement())
  projectionId  Int
  projection    Projection @relation(fields: [projectionId], references: [id], onDelete: Cascade)
  
  employeeId    Int
  employee      User      @relation("NotificationsReceived", fields: [employeeId], references: [id], onDelete: Cascade)
  
  // Notification Details
  type          String    @default("PROJECTION_ASSIGNED")  // PROJECTION_ASSIGNED, TIME_EXTENSION_APPROVED, TIME_EXTENSION_DENIED, etc.
  title         String
  message       String
  actionUrl     String?
  
  // Tracking
  isRead        Boolean   @default(false)
  readAt        DateTime?
  isDismissed   Boolean   @default(false)
  dismissedAt   DateTime?
  
  createdAt     DateTime  @default(now())
  
  @@index([employeeId])
  @@index([projectionId])
  @@index([isRead])
}

model ProjectionAction {
  id            Int       @id @default(autoincrement())
  projectionId  Int
  projection    Projection @relation(fields: [projectionId], references: [id], onDelete: Cascade)
  
  employeeId    Int
  employee      User      @relation("ProjectionActions", fields: [employeeId], references: [id], onDelete: Cascade)
  
  // Action Type & Details
  actionType    String    // ACCEPT, REJECT, REQUEST_TIME, SWITCH_PROJECTION, PAUSE, RESUME, COMPLETE
  details       Json?     // Additional metadata (e.g., { "additionalMinutes": 30 })
  reason        String?   // Why they took this action
  
  createdAt     DateTime  @default(now())
  
  @@index([projectionId])
  @@index([employeeId])
  @@index([actionType])
}
